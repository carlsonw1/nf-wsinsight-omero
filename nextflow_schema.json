{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "WSInsight OMERO+ Pipeline",
  "description": "Run WSInsight on pathology slides, convert images to OME-TIFF, and upload images plus annotations to OMERO+.",
  "type": "object",
  "properties": {
    "wsi_dir": {
      "type": "string",
      "title": "Input image location",
      "description": "S3 prefix or path containing .svs files."
    },
    "outdir": {
      "type": "string",
      "title": "Output folder",
      "description": "Output directory for WSInsight results and converted images."
    },
    "annotation_dir": {
      "type": "string",
      "title": "Annotation CSV folder",
      "description": "Folder containing .ome.csv.gz files."
    },
    "model": {
      "type": "string",
      "title": "WSInsight model",
      "default": "breast-tumor-resnet34.tcga-brca",
      "enum": [
        "breast-tumor-resnet34.tcga-brca"
      ]
    },
    "model_path": {
      "type": "string",
      "title": "Custom model path"
    },
    "config_json": {
      "type": "string",
      "title": "WSInsight config JSON"
    },
    "omero_project_name": {
      "type": "string",
      "title": "OMERO+ project name"
    },
    "omero_dataset_name": {
      "type": "string",
      "title": "OMERO+ dataset name"
    },
    "gpu_queue": {
      "type": "string",
      "title": "GPU queue / cluster",
      "description": "GPU queue or cluster profile to run WSInsight on.",
      "enum": [
        "gpu-a100",
        "gpu-v100",
        "gpu-l40",
        "default"
      ],
      "default": "default"
    },
    "batch_size": {
      "type": "integer",
      "title": "Batch size",
      "default": 32
    },
    "num_workers": {
      "type": "integer",
      "title": "Number of workers",
      "default": 4
    }
  },
  "required": [
    "wsi_dir",
    "outdir",
    "annotation_dir",
    "config_json",
    "omero_project_name",
    "omero_dataset_name"
  ]
}